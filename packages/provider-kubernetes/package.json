{
  "name": "@stack-test/provider-kubernetes",
  "version": "0.1.0",
  "description": "Kubernetes provider for StackTest",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@stack-test/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gattasrikanth/stacktest.git",
    "directory": "packages/provider-kubernetes"
  },
  "homepage": "https://gattasrikanth.github.io/stacktest/",
  "bugs": {
    "url": "https://github.com/gattasrikanth/stacktest/issues"
  },
  "keywords": [
    "infrastructure-testing",
    "iac",
    "testing",
    "stacktest",
    "kubernetes",
    "k8s"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  }
}
