{
  "name": "@stacktest/cli",
  "version": "0.1.0",
  "description": "StackTest command line interface",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "stacktest": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@stacktest/core": "workspace:*",
    "@stacktest/provider-aws-cloudformation": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.2"
  }
}
