{
  "name": "@stacktest/provider-aws-cdk",
  "version": "0.1.0",
  "description": "AWS CDK provider wrapper for StackTest",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@stacktest/core": "workspace:*",
    "@stacktest/provider-aws-cloudformation": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.2"
  }
}
